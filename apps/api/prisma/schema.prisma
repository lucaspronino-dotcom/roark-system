generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id        String   @id @default(uuid()) @db.Uuid
  firstName String
  lastName  String
  dni       String   @unique
  phone     String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant?
  owner  Owner?

  @@map("people")
}

model Tenant {
  id            String   @id @default(uuid()) @db.Uuid
  personId      String   @unique @db.Uuid
  rentalAddress String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@map("tenants")
}

model Owner {
  id                 String   @id @default(uuid()) @db.Uuid
  personId           String   @unique @db.Uuid
  address            String
  city               String
  transferAliasOrCbu String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  person          Person          @relation(fields: [personId], references: [id], onDelete: Cascade)
  propertyOwners  PropertyOwner[]
  contracts       Contract[]

  @@map("owners")
}

model Property {
  id        String   @id @default(uuid()) @db.Uuid
  folder    String
  address   String
  type      String
  status    String
  city      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owners    PropertyOwner[]
  contracts Contract[]

  @@unique([folder, address])
  @@map("properties")
}

model PropertyOwner {
  id          String   @id @default(uuid()) @db.Uuid
  propertyId  String   @db.Uuid
  ownerId     String   @db.Uuid
  isPrimary   Boolean  @default(false)
  participation Float  @default(100)
  administration Float @default(0)
  commission   Float   @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner    Owner    @relation(fields: [ownerId], references: [id], onDelete: Restrict)

  @@unique([propertyId, ownerId])
  @@map("property_owners")
}

model Contract {
  id         String         @id @default(uuid()) @db.Uuid
  folder     String
  startDate  DateTime
  endDate    DateTime
  status     ContractStatus
  propertyId String         @db.Uuid
  tenantId   String         @db.Uuid
  ownerId    String         @db.Uuid
  settings   Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  owner    Owner    @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  receipts Receipt[]

  @@map("contracts")
}

model Receipt {
  id         String      @id @default(uuid()) @db.Uuid
  number     Int         @unique
  kind       ReceiptKind
  date       DateTime
  total      Float
  paid       Float
  balance    Float
  personName String
  contractId String      @db.Uuid
  pdfBase64  String
  snapshot   Json
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([personName, kind])
  @@map("receipts")
}

enum ContractStatus {
  ACTIVE
  EXPIRED
}

enum ReceiptKind {
  OWNER_SETTLEMENT
  TENANT_SETTLEMENT
}
